# ============================================================
# TeacherManager — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---------- App ----------
APP_NAME=TeacherManager
APP_ENV=development
# Options: development, staging, production
DEBUG=true
LOG_LEVEL=info

# ---------- Server ----------
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ---------- Database (Postgres) ----------
DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5432/teachermanager
# For Alembic (sync driver):
DATABASE_URL_SYNC=postgresql://postgres:changeme@localhost:5432/teachermanager

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0

# ---------- JWT / Auth ----------
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- Sentry (APM) ----------
SENTRY_DSN=
# Leave blank to disable; set to your project DSN in staging/production.
SENTRY_TRACES_SAMPLE_RATE=0.2

# ---------- Seeding ----------
INITIAL_ADMIN_PASSWORD=
INITIAL_USER_PASSWORD=
# Required when APP_ENV != development. Set FORCE_SEED_IN_PROD=true to allow.
FORCE_SEED_IN_PROD=false

# ---------- PDF / WeasyPrint ----------
# No extra env needed; chrome-headless is a build dependency.

# ---------- PWA ----------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Generate with: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v)"

# ---------- Optional: OAuth / SSO ----------
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# OAUTH_AUTHORITY_URL=

# ---------- Optional: SMS ----------
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
